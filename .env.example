# Atlas Prime local development defaults.
# Copy to .env before running `make up`.

APP_ENV=development

# Frontend
WEB_PORT=3001
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
ATLAS_API_BASE_URL=http://api:8000
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# API
API_PORT=8000
ATLAS_HEALTH_SKIP_DEPENDENCIES=false
DATABASE_URL=postgresql://atlas:atlas@postgres:5432/atlas_prime
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Clerk placeholders; real values stay out of git.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUTHORIZED_PARTIES=http://localhost:3001
ATLAS_ALLOW_DEV_AUTH_HEADERS=false

# PostgreSQL
POSTGRES_PORT=15432
POSTGRES_DB=atlas_prime
POSTGRES_USER=atlas
POSTGRES_PASSWORD=atlas

# Redis
REDIS_PORT=16379

# MinIO / S3-compatible storage
MINIO_ROOT_USER=atlasminio
MINIO_ROOT_PASSWORD=atlasminiopassword
MINIO_ENDPOINT=http://minio:9000
MINIO_CONSOLE_URL=http://localhost:9001
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=atlasminio
MINIO_SECRET_KEY=atlasminiopassword
MINIO_BUCKET_ORIGINALS=atlas-originals
MINIO_BUCKET_PROCESSED=atlas-processed
ATLAS_UPLOAD_MAX_BYTES=104857600

# Worker
WORKER_CONCURRENCY=1
